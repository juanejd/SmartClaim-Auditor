
# Supported: "groq" (default) | "ollama" (local, requires langchain-ollama)
AUDIT_LLM_PROVIDER=groq

# --- Groq (required when AUDIT_LLM_PROVIDER=groq) ---
GROQ_API_KEY=

# --- Groq model selection ---
GROQ_MODEL=llama-3.1-8b-instant

# --- Node temperatures ---
AUDIT_ANALYST_TEMPERATURE=0.2
AUDIT_AUDITOR_TEMPERATURE=0.0

# --- Token budget ---
AUDIT_MAX_TOKENS=512

# --- Ollama (required when AUDIT_LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b
